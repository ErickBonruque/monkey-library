# String de conexão do banco SQLite (relativa à pasta prisma/)
DATABASE_URL="file:./dev.db"

# Porta em que o servidor Fastify irá rodar
PORT=3333

# Segredo usado para assinar os tokens JWT (mínimo 16 caracteres; obrigatório)
JWT_SECRET="troque-este-segredo-em-producao"

# Origem permitida para CORS (front-end Next.js)
CORS_ORIGIN="http://localhost:3000"

# URL base do front-end, usada para montar o link dos convites por e-mail.
# Se ausente, usa a primeira origem de CORS_ORIGIN.
FRONTEND_URL="http://localhost:3000"

# --- E-mail (convites) -------------------------------------------------------
# Se nenhuma variável SMTP_* for definida, o sistema cria automaticamente uma
# conta de testes no Ethereal e devolve uma URL de pré-visualização do e-mail
# (ideal para demonstração). Para usar um SMTP real, preencha abaixo:
# SMTP_HOST="smtp.seuprovedor.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="usuario"
# SMTP_PASS="senha"
# MAIL_FROM="Sistema de Estoque <no-reply@seudominio.com>"
