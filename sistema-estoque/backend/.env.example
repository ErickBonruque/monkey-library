# String de conexão do banco SQLite (relativa à pasta prisma/)
DATABASE_URL="file:./dev.db"

# Porta em que o servidor Fastify irá rodar
PORT=3333

# Segredo usado para assinar os tokens JWT
JWT_SECRET="troque-este-segredo-em-producao"

# Origem permitida para CORS (front-end Next.js)
CORS_ORIGIN="http://localhost:3000"
